# Conexion al Host
DB_HOST=127.0.0.1
DB_PORT=3306

# Credenciales extraidas de tu docker-compose.yaml
DB_NAME=inventario_db
DB_USER=inventario_user
DB_PASSWORD=inventario_pass

# Configuration for MQTT Publisher
MQTT_BROKER_HOST = "localhost" # O la IP de tu broker Mosquitto
MQTT_BROKER_PORT = 1883 # Puerto estándar MQTT
MQTT_USERNAME = "admin" # Tu usuario
MQTT_PASSWORD = "admin" # Tu contraseña (admin)
MQTT_TOPIC = "inventario/palets/escaneados" # El canal al que publicar
MQTT_CLIENT_ID = "palet_publisher_main_app" # ID único para el cliente MQTT

# Configuration for YOLO path
YOLO_MODEL_PATH="model.pt"